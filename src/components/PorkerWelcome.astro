---
import { Image } from 'astro:assets';
import porkerBorder_NoType from '../assets/porkerBorder_NoType.svg';
import porkerBorder_OnlyType from '../assets/porkerBorder_OnlyType.svg';
---

<div id="container">
	<div class="neon-wrapper">
		<Image src={${import.meta.env.BASE_URL}porkerBorder_NoType} alt="Porker Border" class="neon-svg blink-border" />
		<Image src={${import.meta.env.BASE_URL}porkerBorder_OnlyType} alt="Porker Type" class="neon-svg blink-type" />
	</div>

	<nav class="neon-nav">
		<a href={${import.meta.env.BASE_URL}about} class="neon-button">ABOUT US</a>
		<a href={${import.meta.env.BASE_URL}menu} class="neon-button">MENU</a>
		<a href="https://www.google.com/maps/reserve/v/waitlist?c=gX3QiII5N7w&source=pa&opi=89978449&hl=en-CA&gei=GzCmafqyDcGs0PEPhLiBqQg&sourceurl=https://www.google.com/search?q%3Dporker%2Bface%2B%28korean%2Bpork%2Bbelly%29%26rlz%3D1C1VDKB_enCA1113CA1113%26oq%3Dporke%26gs_lcrp%3DEgZjaHJvbWUqBggBEEUYOzIGCAAQRRg8MgYIARBFGDsyBggCEEUYOzIGCAMQRRg5MgYIBBBFGDsyBggFEEUYOzIGCAYQRRg9MgYIBxBFGD3SAQgyMTgxajBqN6gCALACAA%26sourceid%3Dchrome%26ie%3DUTF-8&ps=2" class="neon-button">JOIN THE WAITLIST</a>
	</nav>
</div>

<style>
	#container {
		position: relative; 
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100%;
		height: 100vh;
		/* 핵심 픽스: 화면 밖으로 빛 퍼짐이나 요소가 튀어나가서 여백이 생기는 것을 완벽히 차단 */
		overflow: hidden; 
	}

	.neon-wrapper {
		display: grid;
		place-items: center;
		animation: move-to-top 1s cubic-bezier(0.25, 1, 0.5, 1) 1.5s forwards;
	}

	.neon-svg {
		grid-area: 1 / 1;
		width: 400px;
		height: auto;
		filter: drop-shadow(0 0 5px #fc35d1) drop-shadow(0 0 15px #fc35d1) drop-shadow(0 0 30px #fc35d1);
		opacity: 0;
	}

	.blink-border {
		animation: turn-on-border 1.2s ease-in forwards;
	}

	.blink-type {
		animation: turn-on-type 0.9s ease-in forwards;
		animation-delay: 0.2s; 
	}

	/* --- Navigation Styles --- */
	.neon-nav {
		position: absolute;
		top: 55%; 
		/* 레이아웃 깨짐 픽스: left 50% 대신 전체 너비를 잡고 내부에서 중앙 정렬 */
		left: 0;
		width: 100%; 
		display: flex;
		justify-content: center;
		flex-direction: row;
		gap: 32px; 
		opacity: 0; 
		/* translate(-50%)를 빼고 단순히 위로 올라오는 애니메이션만 적용 */
		animation: fade-in-up 0.8s ease-out 2.8s forwards;
	}

	.neon-button {
		padding: 12px;
		color: #ffffff; /* 하얀색 텍스트 */
		text-decoration: none;
		font-weight: bold;
		font-size: 1.1rem;
		letter-spacing: 2px;
		border: none; /* 테두리 완벽 제거 */
		background-color: transparent;
		transition: all 0.3s ease;
		
		/* 핑크색 텍스트 네온 글로우 */
		text-shadow: 0 0 5px #fc35d1, 0 0 15px #fc35d1, 0 0 30px #fc35d1;
	}

	.neon-button:hover {
		color: #ffffff;
		/* 마우스 올렸을 때 더 밝게 빛남 */
		text-shadow: 0 0 10px #fc35d1, 0 0 25px #fc35d1, 0 0 50px #fc35d1;
		transform: scale(1.1); 
	}

	/* --- Animations --- */
	@keyframes move-to-top {
		100% {
			transform: translateY(-35vh) scale(0.4);
		}
	}

	/* 중앙 정렬 버그를 일으키던 X축 이동을 제거하고 Y축 이동만 남김 */
	@keyframes fade-in-up {
		0% {
			opacity: 0;
			transform: translateY(20px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes turn-on-border {
		0% { opacity: 0; }
		10% { opacity: 1; }
		20% { opacity: 0; }
		30% { opacity: 1; }
		40% { opacity: 0.2; }
		50% { opacity: 1; }
		60% { opacity: 0.5; }
		70%, 100% { opacity: 1; } 
	}

	@keyframes turn-on-type {
		0% { opacity: 0; }
		15% { opacity: 1; }
		25% { opacity: 0; }
		45% { opacity: 1; }
		55% { opacity: 0; }
		65% { opacity: 0.3; }
		80%, 100% { opacity: 1; } 
	}

	/* --- Mobile Responsiveness --- */
	@media (max-width: 768px) {
		#container {
			padding: 24px; 
			box-sizing: border-box;
		}

		.neon-svg {
			width: 100%; 
			max-width: 320px; 
		}

		.neon-nav {
			flex-direction: column;
			align-items: center; /* 세로 모드에서도 완벽한 중앙 정렬 유지 */
			top: 50%; 
			gap: 20px;
		}

		@keyframes move-to-top {
			100% {
				transform: translateY(-30vh) scale(0.5); 
			}
		}
	}
</style>