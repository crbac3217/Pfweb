---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="about-wrapper">
		<header class="page-header">
			<h1 class="neon-title">PORKER F♠CE</h1>
			<p class="short-intro">
				All-You-Can-Eat Korean BBQ in Burnaby. <br/>
				Premium cuts, endless drinks, zero compromises.
			</p>
		</header>

		<div class="info-grid">
			<div class="info-panel">
				<div class="info-block">
					<h2 class="panel-title">LOCATION</h2>
					<p class="data-text">4455 Lougheed Hwy.<br/>Burnaby, BC V5C 3Z2</p>
					<p class="data-text highlight">
	                    <a href="tel:+16044289227" style="color: inherit; text-decoration: none;">+1 604-428-9227</a>
                    </p>
				</div>

				<div class="info-block">
					<h2 class="panel-title">HOURS</h2>
					<div class="hours-container">
						<div class="day">SUN - THU</div>
						<div class="time">11:30 AM - 3:30 PM<br/>4:30 PM - 10:00 PM</div>

						<div class="day">FRI</div>
						<div class="time">11:30 AM - 3:30 PM<br/>4:30 PM - 11:00 PM</div>

						<div class="day">SAT</div>
						<div class="time">11:30 AM - 11:00 PM</div>
					</div>
				</div>
			</div>

			<div class="map-panel">
				<iframe 
					src="https://maps.google.com/maps?q=Porker+Face+Burnaby&t=&z=15&ie=UTF8&iwloc=&output=embed" 
					width="100%" 
					height="100%" 
					style="border:0;" 
					allowfullscreen="" 
					loading="lazy">
				</iframe>
			</div>
		</div>

		<div class="footer-action">
			<a href="/" class="neon-button">BACK TO HOME</a>
		</div>
	</div>
</Layout>

<style>
	.about-wrapper {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		width: 100%;
		min-height: 100vh;
		padding: 40px 24px;
		box-sizing: border-box;
		background-color: transparent;
	}

	.page-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.neon-title {
		font-size: 3rem;
		margin: 0 0 1rem 0;
		color: #ffffff;
		text-shadow: 0 0 5px #fc35d1, 0 0 15px #fc35d1, 0 0 30px #fc35d1;
		letter-spacing: 4px;
	}

	.short-intro {
		color: #e0e0e0;
		font-size: 1.1rem;
		line-height: 1.6;
		margin: 0;
		letter-spacing: 1px;
	}

	.info-grid {
		display: grid;
		grid-template-columns: 1fr 1.5fr; 
		gap: 40px;
		max-width: 900px;
		width: 100%;
		margin-bottom: 4rem;
	}

	.info-panel {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.info-block {
		border-left: 2px solid #fc35d1;
		padding-left: 1.5rem;
	}

	.panel-title {
		color: #fc35d1;
		font-size: 1.2rem;
		margin: 0 0 1.5rem 0;
		letter-spacing: 2px;
	}

	.data-text {
		color: #ffffff;
		font-size: 1.05rem;
		line-height: 1.5;
		margin: 0 0 0.5rem 0;
	}

	.highlight {
		color: #fc35d1;
		font-weight: bold;
		text-shadow: 0 0 8px rgba(252, 53, 209, 0.5);
	}

	/* 핵심: 지저분한 정렬을 고치기 위한 Grid 설정 */
	.hours-container {
		display: grid;
		grid-template-columns: 95px 1fr; /* 요일 칸을 95px로 고정, 나머지는 시간 칸이 꽉 채움 */
		row-gap: 1.2rem;
		column-gap: 1rem;
		color: #e0e0e0;
		font-size: 0.95rem;
	}

	.day {
		font-weight: bold;
		color: #ffffff;
		letter-spacing: 1px;
		padding-top: 2px; /* 시간 텍스트와 위아래 눈높이 맞춤 */
	}

	.time {
		text-align: left; /* 좌측 정렬로 깔끔하게 떨어지게 만듦 */
		line-height: 1.5;
		color: #aaaaaa;
	}

	.map-panel {
		width: 100%;
		min-height: 350px;
		border: 1px solid rgba(252, 53, 209, 0.4);
		border-radius: 4px; 
		overflow: hidden;
		box-shadow: 0 0 20px rgba(252, 53, 209, 0.1);
	}

	.footer-action {
		text-align: center;
	}

	.neon-button {
		padding: 12px 32px;
		color: #ffffff;
		text-decoration: none;
		font-weight: bold;
		font-size: 1rem;
		letter-spacing: 2px;
		border: 1px solid #fc35d1;
		background: transparent;
		transition: all 0.3s ease;
		box-shadow: 0 0 10px rgba(252, 53, 209, 0.3), inset 0 0 10px rgba(252, 53, 209, 0.2);
		text-shadow: 0 0 5px #fc35d1;
	}

	.neon-button:hover {
		background-color: #fc35d1;
		color: #000000;
		box-shadow: 0 0 20px #fc35d1, inset 0 0 10px #fc35d1;
		text-shadow: none;
	}

	@media (max-width: 768px) {
		.info-grid {
			grid-template-columns: 1fr;
			gap: 30px;
		}
		.map-panel {
			min-height: 250px;
		}
		.neon-title {
			font-size: 2.2rem;
		}
	}
</style>